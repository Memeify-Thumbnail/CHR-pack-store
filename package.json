{
  "name": "chr-pack-store",
  "module": "src/app.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run build:css && bun --hot run src/dev.ts",
    "build:css": "bunx tailwindcss -i src/styles/globals.css -o public/styles/globals.css",
    "build": "bun run build:css",
    "start": "bun run build && bun run src/dev.ts"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/bun": "latest",
    "tailwindcss": "^4.3.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/html": "^1.4.2",
    "@elysiajs/static": "^1.4.10",
    "elysia": "^1.4.28"
  }
}
